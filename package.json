{
  "name": "assembly-concierge-api",
  "version": "1.0.0",
  "description": "Assembly Concierge — Phase 1 Backend API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/src/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit 2>&1"
  },
  "dependencies": {
    "@types/pg": "^8.18.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.3",
    "pg": "^8.19.0",
    "sql.js": "^1.11.0",
    "stripe": "^20.4.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "testTimeout": 15000
  }
}
