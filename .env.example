# Assembly Concierge — Phase 1 Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | staging | production
PORT=3000                     # HTTP port the API listens on

# ─── Webhook Security ─────────────────────────────────────────────────────────
# HMAC-SHA256 secret used to verify incoming payment webhooks.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=replace_with_32_random_bytes_hex

# ─── Payment Processor (Stripe) ───────────────────────────────────────────────
# Your Stripe secret key (sk_test_... for staging, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_replace_me
# Your Stripe webhook signing secret (whsec_...) — from Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ─── SMS Provider ─────────────────────────────────────────────────────────────
# Twilio credentials (or swap for another provider — only used in notification helpers)
SMS_PROVIDER=twilio           # twilio | vonage | openphone
SMS_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMS_AUTH_TOKEN=replace_me
SMS_FROM_NUMBER=+15125550100  # Your Twilio number (must be SMS-capable)

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid       # sendgrid | postmark | smtp
EMAIL_API_KEY=SG.replace_me
EMAIL_FROM_ADDRESS=jobs@assemblyconcierge.com
ADMIN_EMAIL=admin@assemblyconcierge.com
ADMIN_PHONE=+15125550199      # Admin mobile for DISPATCH_FAILED alerts

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_BASE_URL=https://assemblyconcierge.com   # Public URL (no trailing slash)
# Used to build: /job/{jobCode} and /respond/{jobCode}/{attemptId} links

# ─── Airtable (optional sync — Make handles writes, this is for direct API use) ─
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.replace_me
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_JOBS_TABLE=Jobs
AIRTABLE_CONTRACTORS_TABLE=Contractors

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use in-memory SQLite (development only).
# Set to a PostgreSQL connection string for staging/production.
# DATABASE_URL=postgresql://user:password@host:5432/assembly_concierge
